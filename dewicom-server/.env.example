# Copier ce fichier en .env et adapter les valeurs

# Port HTTP + WebSocket exposé sur le host
# Changer si le port 3001 est déjà utilisé par un autre service
DEWICOM_PORT=3001

# Mode annoncé aux clients (docker | dedicated)
SERVER_MODE=docker

# Nom affiché dans l'interface des clients
SERVER_NAME=DewiCom-Server
