{
  "name": "dewicom-desktop",
  "version": "1.3.1",
  "description": "DewiCom Desktop - Application PTT cross-platform",
  "author": {
    "name": "dewiweb",
    "email": "dewi@dewicom.app"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dewiweb/dewicom.git"
  },
  "main": "main.js",
  "scripts": {
    "start": "NODE_EXTRA_CA_CERTS=$(mkcert -CAROOT)/rootCA.pem electron .",
    "build:linux": "electron-builder --linux",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --linux --mac --win"
  },
  "build": {
    "appId": "com.dewicom.desktop",
    "productName": "DewiCom",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!node_modules/.bin",
      "!**/*.{iml,o,hprof,orig,pyc,pyo,rbc,swp,csproj,sln,xproj}"
    ],
    "extraResources": [
      {
        "from": "../shared/public",
        "to": "public"
      }
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "AudioVideo",
      "desktop": {
        "Name": "DewiCom",
        "Comment": "Application PTT inter-appareils sur réseau local",
        "Categories": "AudioVideo;Audio;Network;",
        "Keywords": "PTT;radio;intercom;"
      }
    },
    "deb": {
      "afterInstall": "build/linux/postinst.sh",
      "afterRemove": "build/linux/prerm.sh"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "DewiCom-Setup-${version}.exe"
    },
    "nsis": {
      "include": "build/installer.nsh",
      "perMachine": true,
      "oneClick": false
    }
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "express": "^5.2.1",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.3"
  }
}
